# ─────────────────────────────────────────────────────────────────
# VChron Frontend — Environment Variables
# Copy this file to .env for local dev, or add these as Environment
# Variables in your hosting dashboard (Vercel / Coolify etc.)
# ─────────────────────────────────────────────────────────────────

# Backend API base URL — NO trailing slash
# Falls back to http://localhost:8000 if not set
VITE_BACKEND_URL=https://your-backend-domain.com
